          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e_scan_dec" edge="1" parent="1" source="step_scan" target="step_decision" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#87867F;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_dec_yes" edge="1" parent="1" source="step_decision" target="step_yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#788C5D;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;">
          <mxGeometry relative="1" as="geometry"/>
          <mxCell id="e_dec_yes_lbl" vertex="1" parent="e_dec_yes" style="text;html=1;align=center;fontColor=#5F6F4A;fontStyle=1;fontSize=12;">
            <mxGeometry x="0.1" y="-10" width="50" height="20" as="geometry"/>
          </mxCell>
        </mxCell>
        <mxCell id="e_dec_no" edge="1" parent="1" source="step_decision" target="step_qualify" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#D97757;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_qual_syn" edge="1" parent="1" source="step_qualify" target="step_synth" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#D97757;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;">
