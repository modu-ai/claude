        <mxCell id="step1_box" value="① 사용자 입력" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3DACC;strokeColor=#C9BCA6;fontColor=#141413;fontFamily=Helvetica;fontStyle=1;align=center;verticalAlign=top;spacingTop=8;fontSize=12;" vertex="1" parent="1">
