        <mxCell id="title" value="자동화 레시피 공통 파이프라인" vertex="1" parent="1" style="text;align=center;verticalAlign=middle;html=1;fontFamily=Helvetica;fontSize=20;fontStyle=1;fontColor=#141413;">
          <mxGeometry x="200" y="20" width="700" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="부서별 레시피는 달라 보여도 트리거 → 라우팅 → PC 실행 → 결과 알림, 같은 한 줄의 흐름을 따른다" vertex="1" parent="1" style="text;align=center;verticalAlign=middle;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#87867F;">
          <mxGeometry x="150" y="54" width="800" height="22" as="geometry"/>
        </mxCell>

        <mxCell id="grp_trigger" value="① 트리거 (Schedule)" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAEAEA;strokeColor=#6E6E6E;verticalAlign=top;fontStyle=1;align=left;spacingLeft=12;fontFamily=Helvetica;fontColor=#141413;fontSize=12;">
          <mxGeometry x="30" y="110" width="260" height="420" as="geometry"/>
        </mxCell>
        <mxCell id="t1" value="재무 — 매일 08:50&#10;환율 + 미결 메일" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D1CFC5;fontColor=#141413;fontFamily=Helvetica;align=center;verticalAlign=middle;fontSize=11;">
          <mxGeometry x="50" y="160" width="220" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="t2" value="품질 — 매일 07:00&#10;전일 불량 대시보드" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D1CFC5;fontColor=#141413;fontFamily=Helvetica;align=center;verticalAlign=middle;fontSize=11;">
          <mxGeometry x="50" y="236" width="220" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="t3" value="SCM — 매주 월 08:00&#10;벤더 리스크 스캔" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D1CFC5;fontColor=#141413;fontFamily=Helvetica;align=center;verticalAlign=middle;fontSize=11;">
          <mxGeometry x="50" y="312" width="220" height="56" as="geometry"/>
