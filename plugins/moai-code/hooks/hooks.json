{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-session-start.sh\"",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-compact.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-session-end.sh\"",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-pre-tool.sh\"",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|Bash"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-post-tool.sh\"",
            "timeout": 10,
            "type": "command",
            "async": true
          },
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/status-transition-ownership.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-stop.sh\"",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/sync-phase-quality-gate.sh\"",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-subagent-stop.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-post-tool-failure.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-subagent-start.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-user-prompt-submit.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-teammate-idle.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-task-completed.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "project_settings|local_settings|skills",
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-config-change.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "rate_limit|authentication_failed|billing_error|max_output_tokens",
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-stop-failure.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-post-compact.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-instructions-loaded.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-cwd-changed.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-file-changed.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": ".env|.envrc|.gitignore"
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-permission-denied.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/moai/handle-permission-request.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  }
}
