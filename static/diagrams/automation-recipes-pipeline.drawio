        <mxCell id="route" value="② 라우팅 (Dispatch)&#10;&#10;지시를 대기 중인 PC로 배달&#10;&quot;마지막으로 사용한 PC&quot; 기준" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D97757;strokeColor=#B85C3E;fontColor=#FFFFFF;fontFamily=Helvetica;fontStyle=1;align=center;verticalAlign=middle;fontSize=12;">
