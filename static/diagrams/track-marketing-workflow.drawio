        <mxCell id="title" value="마케팅 트랙 — 한 줄 요청이 산출물이 되기까지" style="text;align=center;verticalAlign=middle;html=1;fontFamily=Helvetica;fontSize=20;fontStyle=1;fontColor=#141413;" vertex="1" parent="1">
          <mxGeometry x="150" y="20" width="800" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="사용자 한 줄 입력 → 시스템 인터뷰(맥락 수집) → 스킬 체인 자동 실행 → 품질 검수 → 산출물" style="text;align=center;verticalAlign=middle;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#87867F;" vertex="1" parent="1">
