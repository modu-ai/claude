{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh SessionStart\"",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh PreCompact\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh SessionEnd\"",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh PreToolUse\"",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh PostToolUse\"",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh Stop\"",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh SubagentStop\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh PostToolUseFailure\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh SubagentStart\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh UserPromptSubmit\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh TeammateIdle\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh TaskCompleted\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "project_settings|local_settings|skills",
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh ConfigChange\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "rate_limit|authentication_failed|billing_error|max_output_tokens",
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh StopFailure\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh PostCompact\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh InstructionsLoaded\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh CwdChanged\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": ".env|.envrc|.gitignore",
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh FileChanged\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh PermissionDenied\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh PermissionRequest\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  }
}
