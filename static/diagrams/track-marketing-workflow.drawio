        </mxCell>
        <mxCell id="step1_body" value="&quot;B2B SaaS 브랜드&#10;리뉴얼안 만들어줘&quot;&#10;&#10;(한 줄 자연어 요청)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAF9F5;strokeColor=#D1CFC5;fontColor=#141413;fontFamily=Helvetica;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1">
