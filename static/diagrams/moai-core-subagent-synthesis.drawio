          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_agents_active" edge="1" parent="1" source="out_agents" target="out_active" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#B85C3E;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="title" value="moai-core · Subagent Synthesis (프로젝트 맞춤 에이전트 합성)" vertex="1" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=18;fontStyle=1;fontColor=#141413;">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="설치된 플러그인을 스캔해 기존 코디네이터를 우선 쓰고, 빈 자리만 새 전담 에이전트로 합성한다." vertex="1" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;fontColor=#87867F;">
          <mxGeometry x="40" y="48" width="900" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="grp_input" value="입력 — 설치된 cowork 플러그인 (사용자 환경)" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3DACC;strokeColor=#C9BCA6;verticalAlign=top;fontStyle=1;fontColor=#141413;dashed=1;">
          <mxGeometry x="40" y="90" width="1080" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="in_skills" value="스킬&#10;(단일 작업 도구)&#10;&#10;예: pptx-designer&#10;     ai-slop-reviewer" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D1CFC5;fontColor=#141413;fontFamily=Helvetica;verticalAlign=top;">
          <mxGeometry x="80" y="130" width="200" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="in_coord" value="코디네이터 에이전트 (번들)&#10;여러 스킬을 묶은 완성형 실행기&#10;&#10;예: business-plan-coordinator =&#10;  strategy-planner → market-analyst&#10;  → IR → ai-slop → humanize → pptx" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D97757;strokeColor=#B85C3E;fontColor=#FFFFFF;fontFamily=Helvetica;fontStyle=1;verticalAlign=top;">
          <mxGeometry x="320" y="120" width="460" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="in_projctx" value="프로젝트 맥락&#10;(인터뷰로 수집)&#10;&#10;어떤 산출물을&#10;얼마나 자주 만드나" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D1CFC5;fontColor=#141413;fontFamily=Helvetica;verticalAlign=top;">
          <mxGeometry x="820" y="130" width="270" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="grp_pipeline" value="합성 파이프라인 — /project Phase 2 → 3 → 3.5" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAF9F5;strokeColor=#D1CFC5;verticalAlign=top;fontStyle=1;fontColor=#141413;">
          <mxGeometry x="40" y="250" width="1080" height="360" as="geometry"/>
        </mxCell>

        <mxCell id="step_scan" value="① SCAN — 인벤토리 (Phase 2)&#10;&#10;설치된 플러그인의 agents/*.md&#10;frontmatter를 동적 스캔.&#10;코디네이터 + 스킬 전체 목록을&#10;inventory.json 로 도출 (하드코딩 X)" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D97757;strokeWidth=2;fontColor=#141413;fontFamily=Helvetica;verticalAlign=top;fontStyle=1;">
          <mxGeometry x="80" y="300" width="280" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="step_decision" value="② 매칭되는&#10;코디네이터가 있는가?&#10;(Phase 3 결정 규칙)" vertex="1" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FAF9F5;strokeColor=#D97757;strokeWidth=2;fontColor=#141413;fontFamily=Helvetica;fontStyle=1;">
          <mxGeometry x="500" y="300" width="240" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="step_yes" value="③-A 기존 코디네이터 우선&#10;(&quot;재사용&quot; 경로)&#10;&#10;CLAUDE.md 체인 표에&#10;해당 코디네이터를 실행기로 지정.&#10;새 에이전트 생성 없음." vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#788C5D;strokeColor=#5F6F4A;fontColor=#FFFFFF;fontFamily=Helvetica;verticalAlign=top;fontStyle=1;">
          <mxGeometry x="820" y="300" width="270" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="step_qualify" value="③-B 자격 판정 (Phase 3.5)&#10;아래 중 하나 이상 만족?&#10;&#10;(a) 고정 다단계 + 비우회 게이트&#10;(b) 병렬 fan-out (여러 산출물 동시)&#10;(c) 사용자가 매우 자주 반복" vertex="1" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FAF9F5;strokeColor=#D97757;strokeWidth=2;fontColor=#141413;fontFamily=Helvetica;verticalAlign=top;">
          <mxGeometry x="470" y="470" width="300" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="step_synth" value="④ SYNTHESIZE — 신규 전담 에이전트 합성&#10;&#10;./.claude/agents/&lt;name&gt;.md 작성&#10;(도구: Read,Grep,Glob,Write,Edit,WebSearch)&#10;새 세션 / /reload-plugins 에서 활성화" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D97757;strokeColor=#B85C3E;fontColor=#FFFFFF;fontFamily=Helvetica;verticalAlign=top;fontStyle=1;">
          <mxGeometry x="820" y="470" width="270" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="step_inline" value="⑤ 인라인 스킬 체인&#10;(&quot;충분함&quot; 경로)&#10;&#10;단순 1-2단계거나&#10;자격 미충족 → 에이전트 생성 X.&#10;CLAUDE.md에 스킬 나열로 처리." vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D1CFC5;fontColor=#141413;fontFamily=Helvetica;verticalAlign=top;fontStyle=1;">
          <mxGeometry x="80" y="470" width="280" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="lbl_yes" value="예" vertex="1" parent="1" style="text;html=1;align=center;fontColor=#5F6F4A;fontStyle=1;fontSize=12;fontFamily=Helvetica;">
          <mxGeometry x="745" y="318" width="40" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="lbl_no" value="아니오" vertex="1" parent="1" style="text;html=1;align=center;fontColor=#B85C3E;fontStyle=1;fontSize=12;fontFamily=Helvetica;">
          <mxGeometry x="540" y="432" width="60" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="lbl_qual_y" value="자격 충족" vertex="1" parent="1" style="text;html=1;align=center;fontColor=#B85C3E;fontStyle=1;fontSize=12;fontFamily=Helvetica;">
          <mxGeometry x="775" y="518" width="80" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="lbl_qual_n" value="미충족" vertex="1" parent="1" style="text;html=1;align=center;fontColor=#87867F;fontStyle=1;fontSize=12;fontFamily=Helvetica;">
          <mxGeometry x="375" y="518" width="70" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="grp_out" value="산출물 — 프로젝트에 기록됨" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3DACC;strokeColor=#C9BCA6;verticalAlign=top;fontStyle=1;fontColor=#141413;dashed=1;">
          <mxGeometry x="40" y="640" width="1080" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="out_claude" value="CLAUDE.md (200라인 이내)&#10;프로젝트 루트&#10;&#10;산출물별 체인 표 기록 —&#10;실행기가 코디네이터면&#10;[에이전트] 표기, 없으면 스킬 나열" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D1CFC5;fontColor=#141413;fontFamily=Helvetica;verticalAlign=top;fontStyle=1;">
          <mxGeometry x="80" y="680" width="320" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="out_agents" value=".claude/agents/&lt;name&gt;.md&#10;프로젝트 맞춤 서브에이전트&#10;&#10;빈 자리만 합성됨 — 기존 코디네이터가&#10;이미 커버하면 생성되지 않음.&#10;우선순위가 번들보다 높음." vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D97757;strokeColor=#B85C3E;fontColor=#FFFFFF;fontFamily=Helvetica;verticalAlign=top;fontStyle=1;">
          <mxGeometry x="460" y="680" width="320" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="out_active" value="다음 세션에서 활성화&#10;&#10;디스크의 에이전트는 세션 시작 시 로드.&#10;합성 직후가 아닌 새 세션(또는 /reload-plugins)&#10;부터 자연어 위임으로 자동 호출됨." vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAF9F5;strokeColor=#D97757;strokeWidth=2;fontColor=#141413;fontFamily=Helvetica;verticalAlign=top;fontStyle=1;">
          <mxGeometry x="840" y="680" width="250" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="grp_legend" value="범례" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D1CFC5;verticalAlign=top;fontStyle=1;fontColor=#141413;">
          <mxGeometry x="40" y="810" width="1080" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="leg1" value="■ 강조/합성 (#D97757) — 새로 만들어지는 것" vertex="1" parent="1" style="text;html=1;align=left;fontColor=#141413;fontSize=11;fontFamily=Helvetica;">
          <mxGeometry x="60" y="835" width="320" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg2" value="■ 재사용/저장소 (#788C5D) — 기존 것을 그대로 쓰는 것" vertex="1" parent="1" style="text;html=1;align=left;fontColor=#141413;fontSize=11;fontFamily=Helvetica;">
          <mxGeometry x="60" y="858" width="320" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg3" value="◆ 판단 — 코디네이터 존재 / 자격 충족 여부" vertex="1" parent="1" style="text;html=1;align=left;fontColor=#141413;fontSize=11;fontFamily=Helvetica;">
          <mxGeometry x="420" y="835" width="320" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg4" value="▭ 외부/경계 (#E3DACC) — 사용자 환경·산출물 컨테이너" vertex="1" parent="1" style="text;html=1;align=left;fontColor=#141413;fontSize=11;fontFamily=Helvetica;">
          <mxGeometry x="420" y="858" width="320" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg5" value="핵심 원칙: 기존 코디네이터를 먼저 쓰고, 빈 자리만 합성 — 에이전트 남출 방지" vertex="1" parent="1" style="text;html=1;align=left;fontColor=#B85C3E;fontSize=11;fontFamily=Helvetica;fontStyle=1;">
          <mxGeometry x="770" y="846" width="330" height="20" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
