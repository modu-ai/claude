        <mxCell id="insight_lbl" value="이 다이어그램이 말하는 핵심" vertex="1" parent="1" style="text;align=left;verticalAlign=middle;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#B85C3E;">
