        <mxCell id="t_note" value="부서마다 내용은 다르지만&#10;모두 &quot;정해진 시각에 알람&quot;" vertex="1" parent="1" style="text;align=center;verticalAlign=middle;html=1;fontFamily=Helvetica;fontSize=10;fontStyle=2;fontColor=#87867F;">
          <mxGeometry x="50" y="460" width="220" height="40" as="geometry"/>
